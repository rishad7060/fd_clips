# Repo-root build context ignore (used by app/api/Dockerfile and pipeline/Dockerfile).
# Keep the context small + never leak secrets into images.

# Secrets / env
.env
.env.*
!.env.docker.example

# Node
**/node_modules
app/api/dist
app/web/.next

# Python
**/__pycache__
**/*.pyc
.venv
venv

# Pipeline runtime artifacts (large; created at runtime in the workspace volume)
workspace
.cache

# Git / editor / OS
.git
.gitignore
.vscode
.idea
*.log
.DS_Store
Thumbs.db

# Docs / screenshots (not needed in images)
screenshots
*.md
!requirements.docker.txt
