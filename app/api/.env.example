# app/api local env. Copy to .env to override. With everything blank the API
# boots in MOCK_MODE: in-memory DB, in-memory queue, fake auth org, stubbed
# Stripe/R2. No Postgres/Redis/Clerk/Stripe keys required.

MOCK_MODE=auto          # auto | true | false
MOCK_AUTH=true          # inject a fake org; no Clerk JWT needed locally

API_PORT=4000

# Leave blank for mock fallbacks:
DATABASE_URL=
REDIS_URL=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
# Payments (PayPal). Two flows are supported:
#  - one-time Orders v2 (buy a credit pack)  -> /billing/checkout + /billing/capture
#  - recurring Subscriptions (monthly plan)   -> /billing/subscribe + /billing/subscription/cancel
# Leave PAYPAL_CLIENT_ID/PAYPAL_SECRET blank for the mock billing fallback:
# checkout/subscribe grant credits locally (subscribe auto-activates).
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# Sandbox by default. SANDBOX -> LIVE switch: set PAYPAL_BASE_URL to
# https://api-m.paypal.com and PAYPAL_MODE=live (and use your LIVE client id/
# secret + LIVE plan ids + LIVE webhook id below).
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_MODE=sandbox
PAYPAL_RETURN_URL=http://localhost:3000/billing?ok=1
PAYPAL_CANCEL_URL=http://localhost:3000/billing?canceled=1
# Pre-created PayPal Billing Plan ids for the monthly subscriptions (create a
# Product + two Plans in the PayPal Dashboard at the prices in billing/plans.ts:
# Starter $7.50/mo, Pro $14.50/mo). Required only for REAL subscriptions.
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_PRO=
# PayPal webhook id (Dashboard -> Webhooks). REQUIRED in real mode: webhook
# grants are rejected unless the PayPal signature verifies against this id.
PAYPAL_WEBHOOK_ID=
R2_BUCKET=focaldive-clips
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
