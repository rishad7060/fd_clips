# app/api local env. Copy to .env to override. With everything blank the API
# boots in MOCK_MODE: in-memory DB, in-memory queue, fake auth org, stubbed
# billing/R2. No Postgres/Redis/Clerk/Polar keys required.

MOCK_MODE=auto          # auto | true | false
MOCK_AUTH=true          # inject a fake org; no Clerk JWT needed locally

API_PORT=4000

# Leave blank for mock fallbacks:
DATABASE_URL=
REDIS_URL=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
# Payments (Polar.sh). Recurring monthly subscriptions via a hosted checkout.
# Leave POLAR_ACCESS_TOKEN blank for the mock billing fallback: /billing/subscribe
# grants credits locally and auto-activates (no real checkout).
POLAR_ACCESS_TOKEN=
# Sandbox by default. SANDBOX -> PRODUCTION switch: set POLAR_BASE_URL to
# https://api.polar.sh and POLAR_MODE=production (with your production token +
# product ids + webhook secret).
POLAR_BASE_URL=https://sandbox-api.polar.sh
POLAR_MODE=sandbox
# Pre-created Polar product ids (UUIDs) for the monthly subscriptions (create a
# Product per tier in the Polar Dashboard at the prices in billing/plans.ts:
# Starter $7.50/mo, Pro $14.50/mo). Required only for REAL subscriptions.
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_PRO=
# Polar webhook secret (whsec_...). REQUIRED in real mode: webhook grants are
# rejected unless the Standard Webhooks signature verifies against this secret.
POLAR_WEBHOOK_SECRET=
# Where Polar returns the buyer after a successful checkout (optional override).
BILLING_SUCCESS_URL=http://localhost:3000/billing?ok=1
BILLING_CANCEL_URL=http://localhost:3000/billing?canceled=1
R2_BUCKET=focaldive-clips
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
