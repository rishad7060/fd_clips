// YT Shorts Clips - Prisma schema (Postgres)
// Every table carries organization_id for tenant scoping + RLS (PROMPT 9b).
// Shapes mirror CONTRACTS.md §1 (Job), §3 (Clip), and §9d (Credit/billing).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  queued
  running
  completed
  failed
  canceled
}

enum JobStage {
  ingest
  transcribe
  score
  extract
  reframe
  captions
  done
}

enum SourceType {
  url
  upload
}

enum PlanTier {
  free
  starter
  pro
}

enum CreditReason {
  grant // subscription / signup grant
  debit // charged on job submit
  refund // returned on job failure
}

// Access level for a User. `user` (default) is a normal creator scoped to their
// own organization; `admin` is a system operator with cross-tenant access to the
// admin dashboard (see app/api/src/admin and app/web/src/app/(admin)).
enum UserRole {
  user
  admin
}

model Organization {
  id        String   @id @default(cuid())
  // Legacy Clerk organization id (or a synthetic id in MOCK_AUTH mode). Optional
  // now that auth is self-hosted (Auth.js + Google): personal orgs provisioned
  // on first Google login do not carry one.
  clerkOrgId String? @unique @map("clerk_org_id")
  name      String
  plan      PlanTier @default(free)
  // Cached running balance in credits (1 credit = 1 source-minute).
  // Default raised 30 -> 60 (Opus parity). MIGRATION REQUIRED: the new default
  // only applies to rows created after `prisma migrate`; existing orgs keep
  // their balance. See migration note in app/api/.env.example.
  creditBalance Int   @default(60) @map("credit_balance")
  stripeCustomerId String? @unique @map("stripe_customer_id")
  // Recurring subscription id from the payment provider (Polar.sh) + last-known
  // status from its webhooks (ACTIVE | SUSPENDED | CANCELLED | EXPIRED). Null on
  // the free tier / before any subscription. MIGRATION REQUIRED (new columns).
  subscriptionId       String? @unique @map("subscription_id")
  subscriptionStatus   String? @map("subscription_status")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  jobs        Job[]
  clips       Clip[]
  credits     CreditLedger[]
  users       User[]
  // The org's own affiliate account (referral program). Auto-created on demand.
  affiliate   Affiliate?

  @@map("organizations")
}

// Individual end-user (self-hosted Auth.js + Google OAuth). On first Google
// login a User is provisioned together with a personal Organization, so all
// existing org-scoped data (jobs/clips/billing) keeps working unchanged.
model User {
  id             String   @id @default(cuid())
  // Google account subject id (`sub`). Null only for non-Google future providers.
  googleId       String?  @unique @map("google_id")
  email          String   @unique
  name           String?
  avatarUrl      String?  @map("avatar_url")
  // Access level. Regular Google signups are `user`; admins are provisioned via
  // the seed script (real) or the in-memory seed (mock) and log in with a
  // password (Credentials provider), never Google.
  role           UserRole @default(user)
  // bcrypt hash for Credentials (admin) login. Null for Google-only users.
  passwordHash   String?  @map("password_hash")
  lastLoginAt    DateTime? @map("last_login_at")
  // The user's personal organization (the tenant boundary for their data).
  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([role])
  @@map("users")
}

model Job {
  id             String     @id @default(cuid())
  organizationId String     @map("organization_id")
  sourceType     SourceType @map("source_type")
  sourceUrl      String?    @map("source_url")
  sourceKey      String?    @map("source_key")
  clipCount      Int        @map("clip_count")
  // JSON caption/template style (CONTRACTS.md §1 style).
  style          Json?
  // JSON Opus-style per-job clip-generation config (aspectRatio, clipLength,
  // genre, includeMoments, processRange). Null = all defaults. Forwarded to
  // run.py --config-json by the worker.
  config         Json?
  status         JobStatus  @default(queued)
  progress       Int        @default(0)
  stage          JobStage   @default(ingest)
  // Source minutes charged for this job (for refund on failure).
  creditsCharged Int        @default(0) @map("credits_charged")
  error          String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  clips        Clip[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("jobs")
}

model Clip {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  jobId          String  @map("job_id")
  // 1-based clip rank (matches order in clips.json.candidates).
  rank           Int
  start          Float
  end            Float
  hookLine       String  @map("hook_line")
  hookTitle      String? @map("hook_title")
  viralityScore  Int     @map("virality_score")
  reason         String
  suggestedTitle String  @map("suggested_title")
  // R2 keys (never exposed raw to the browser - see CONTRACTS.md §5).
  finalKey       String? @map("final_key")
  thumbKey       String? @map("thumb_key")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  job          Job          @relation(fields: [jobId], references: [id])

  @@index([organizationId])
  @@index([jobId])
  @@map("clips")
}

// Editable plan catalog. Seeded from billing/plans.ts defaults on first boot;
// the admin dashboard edits these rows (price, monthly credits, capabilities)
// and the billing/auth layers read the live values via PlansService.
model Plan {
  tier              PlanTier @id
  label             String
  priceUsd          Float    @map("price_usd")
  monthlyCredits    Int      @map("monthly_credits")
  watermark         Boolean
  editingEnabled    Boolean  @map("editing_enabled")
  clipRetentionDays Int?     @map("clip_retention_days")
  maxResolution     String   @default("1080p") @map("max_resolution")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

// Credit ledger - append-only record of grants/debits/refunds.
// Organization.creditBalance is the materialized running total.
model CreditLedger {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  // Positive for grant/refund, negative for debit.
  amount         Int
  reason         CreditReason
  // Optional links for traceability.
  jobId          String?      @map("job_id")
  stripeEventId  String?      @map("stripe_event_id")
  note           String?
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("credit_ledger")
}

// Affiliate account - one per organization (auto-created on first access). Tracks
// the referral funnel (clicks → signups → conversions) and earnings in USD cents.
// commissionRate null = use the global default (AffiliateSetting / config).
model Affiliate {
  id             String   @id @default(cuid())
  organizationId String   @unique @map("organization_id")
  code           String   @unique
  commissionRate Float?   @map("commission_rate")
  clicks         Int      @default(0)
  signups        Int      @default(0)
  conversions    Int      @default(0)
  earnedCents    Int      @default(0) @map("earned_cents")
  paidCents      Int      @default(0) @map("paid_cents")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  referrals    Referral[]

  @@map("affiliates")
}

// A referred organization, attributed to one affiliate. Unique on referredOrgId
// (an org can only ever be referred once). creditedEventIds records the billing
// events already credited so a webhook + confirm replay never double-pays.
model Referral {
  id               String    @id @default(cuid())
  affiliateId      String    @map("affiliate_id")
  code             String
  referredOrgId    String    @unique @map("referred_org_id")
  referredEmail    String?   @map("referred_email")
  // 'signed_up' | 'converted'
  status           String    @default("signed_up")
  earnedCents      Int       @default(0) @map("earned_cents")
  creditedEventIds String[]  @map("credited_event_ids")
  createdAt        DateTime  @default(now()) @map("created_at")
  convertedAt      DateTime? @map("converted_at")

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@map("referrals")
}

// Singleton row holding the global default affiliate commission rate (0–1),
// admin-editable. Falls back to AFFILIATE_COMMISSION_RATE when absent.
model AffiliateSetting {
  id             String   @id @default("global")
  commissionRate Float    @map("commission_rate")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("affiliate_settings")
}
