# YT Shorts Clips — web app environment
#
# Auth is self-hosted (Auth.js v5 + Google OAuth). Leave the auth vars blank to
# run in dev/mock mode (renders without login). Set them to enable Google login.
NEXT_PUBLIC_AUTH_ENABLED=        # "true" to enable the real auth UI + route protection
AUTH_SECRET=                     # NextAuth secret — openssl rand -base64 32
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=                  # Google Cloud Console OAuth 2.0 client id
AUTH_GOOGLE_SECRET=              # ...and client secret
API_INTERNAL_URL=http://localhost:4000   # server-side URL for the API's /auth/sync
# Shared with the API (must match there):
AUTH_JWT_SECRET=                 # signs the API access token (HS256; carries role)
AUTH_INTERNAL_SECRET=            # guards POST /auth/sync + POST /auth/login

# Admin dashboard (/admin): admins sign in at /admin/sign-in with email+password
# (Credentials provider → API /auth/login). No extra web vars — the admin
# credentials live on the API side (ADMIN_EMAIL / ADMIN_PASSWORD). Real admin
# gating needs NEXT_PUBLIC_AUTH_ENABLED=true + the shared secrets above.

# Point at the real NestJS API to use live data. Leave blank for the in-app mock API client.
NEXT_PUBLIC_API_URL=
