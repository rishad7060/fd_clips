# ── Pipeline ───────────────────────────────────────────────
# Leave everything blank to run in MOCK_MODE (no GPU / no paid APIs).
# auto => stays mocked until you set a scoring key OR pick a real backend below.
MOCK_MODE=auto                 # auto | true | false

# ── MVP $0 PATH (v2 — Groq transcribes, Gemini scores, no GPU) ─────────
# The recommended zero-cost setup. Both are free-tier APIs, no GPU, fast.
#   1. Groq key (free):   https://console.groq.com/keys      -> GROQ_API_KEY
#   2. Gemini key (free): https://aistudio.google.com/apikey -> GEMINI_API_KEY
# With both set, MOCK_MODE=auto resolves to REAL automatically.
GROQ_API_KEY=                  # Groq free tier — whisper-large-v3 transcription (the MVP fix)
GROQ_MODEL=whisper-large-v3    # whisper-large-v3 | whisper-large-v3-turbo
GEMINI_API_KEY=                # Google AI Studio key (FREE tier) — the clip-scoring brain
GEMINI_MODEL=gemini-2.0-flash
SCORING_PROVIDER=auto          # auto | gemini | openai | mock
TRANSCRIBE_BACKEND=auto        # auto | groq | whisperx | faster-whisper | mock
FASTER_WHISPER_MODEL=small     # CPU fallback only: tiny|base|small|medium

# ── YouTube download (cookies — fixes "Sign in to confirm you're not a bot") ──
# YouTube often blocks downloads from clean IPs without cookies. Easiest fix:
# point yt-dlp at your logged-in browser. (chrome | edge | firefox | brave | ...)
YTDLP_COOKIES_FROM_BROWSER=    # e.g. chrome   — reuses your browser's YouTube login
YTDLP_COOKIES=                 # OR an exported cookies.txt path (alternative to the above)

# ── Email delivery (Resend — sends the finished clips) ─────────────────
RESEND_API_KEY=                # https://resend.com (free 3k/mo); empty => worker logs instead of sends
EMAIL_FROM=YT Shorts Clips <clips@focaldive.com>

# ── GPU PATH (later, on RunPod) ────────────────────────────────
OPENAI_API_KEY=                # alternative scorer (GPT-4o-mini)
HUGGINGFACE_TOKEN=             # pyannote diarization (GPU only)
WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda           # cuda | cpu

# ── Tooling (auto-detected; set full paths if not on PATH) ─────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ── Storage (Cloudflare R2 / S3 API) ──────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=focaldive-clips
R2_ENDPOINT=

# ── Queue / DB (API + worker) ─────────────────────────────────
DATABASE_URL=postgresql://focaldive:focaldive@localhost:5432/focaldive
REDIS_URL=redis://localhost:6379

# ── Auth (self-hosted: Auth.js v5 + Google OAuth) ─────────────
# Leave blank to run in dev/mock auth mode (app renders without login; the API
# injects a dev org). Fill in to enable real Google login/registration.
NEXT_PUBLIC_AUTH_ENABLED=        # set "true" to turn on the real auth UI + route protection
AUTH_SECRET=                     # NextAuth cookie/session secret — openssl rand -base64 32
AUTH_URL=http://localhost:3000   # public web URL (Google redirects back here)
# Google OAuth 2.0 client (Google Cloud Console → Credentials). Authorized
# redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
API_INTERNAL_URL=http://localhost:4000   # server-side URL web uses to call the API's /auth/sync
# Shared web↔API secrets (MUST be identical in both). openssl rand -base64 32
AUTH_JWT_SECRET=                 # signs/verifies the app API access token (HS256)
AUTH_INTERNAL_SECRET=            # guards the API's internal POST /auth/sync
MOCK_AUTH=                       # auto: real once AUTH_JWT_SECRET set; force with true|false

# ── Payments (Polar.sh: recurring monthly subscriptions) ──
# Leave POLAR_ACCESS_TOKEN blank for the mock billing fallback (subscribe grants
# credits locally and auto-activates; no real checkout).
POLAR_ACCESS_TOKEN=
# Sandbox by default. PRODUCTION switch: POLAR_BASE_URL=https://api.polar.sh,
# POLAR_MODE=production, plus production token/product ids/webhook secret.
POLAR_BASE_URL=https://sandbox-api.polar.sh
POLAR_MODE=sandbox
# Pre-created Polar product ids (UUIDs) per tier (Starter $7.50/mo, Pro $14.50/mo)
# + webhook secret (whsec_...) for signature verification. Required for REAL subs.
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_PRO=
POLAR_WEBHOOK_SECRET=
# Where Polar returns the buyer after checkout (optional overrides).
BILLING_SUCCESS_URL=http://localhost:3000/billing?ok=1
BILLING_CANCEL_URL=http://localhost:3000/billing?canceled=1

# ── App ───────────────────────────────────────────────────────
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
