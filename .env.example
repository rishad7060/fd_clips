# ── Pipeline ───────────────────────────────────────────────
# Leave everything blank to run in MOCK_MODE (no GPU / no paid APIs).
# auto => stays mocked until you set a scoring key OR pick a real backend below.
MOCK_MODE=auto                 # auto | true | false

# ── FREE CPU PATH (real clips, no GPU) ─────────────────────────
# This is the "test now for free" setup: Gemini scores, faster-whisper transcribes
# on CPU, FFmpeg cuts/captions. Slower than GPU and no smart speaker-crop, but real.
#
#   1. Get a free key at https://aistudio.google.com/apikey  and paste below.
#   2. (auto-detected) faster-whisper + ffmpeg handle transcription/cutting on CPU.
#
GEMINI_API_KEY=                # Google AI Studio key (FREE tier) — the clip-scoring brain
GEMINI_MODEL=gemini-2.0-flash
SCORING_PROVIDER=auto          # auto | gemini | openai | mock
TRANSCRIBE_BACKEND=auto        # auto | whisperx | faster-whisper | mock
FASTER_WHISPER_MODEL=small     # tiny | base | small | medium  (bigger = slower, more accurate)

# ── GPU PATH (later, on RunPod) ────────────────────────────────
OPENAI_API_KEY=                # alternative scorer (GPT-4o-mini)
HUGGINGFACE_TOKEN=             # pyannote diarization (GPU only)
WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda           # cuda | cpu

# ── Tooling (auto-detected; set full paths if not on PATH) ─────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ── Storage (Cloudflare R2 / S3 API) ──────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=focaldive-clips
R2_ENDPOINT=

# ── Queue / DB (API + worker) ─────────────────────────────────
DATABASE_URL=postgresql://focaldive:focaldive@localhost:5432/focaldive
REDIS_URL=redis://localhost:6379

# ── Auth (Clerk) ──────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ── Payments (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ── App ───────────────────────────────────────────────────────
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
