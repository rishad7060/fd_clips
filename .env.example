# ── Pipeline ───────────────────────────────────────────────
# Leave keys blank to run in MOCK_MODE (no GPU / no paid APIs needed)
MOCK_MODE=auto                 # auto | true | false  (auto => true when keys missing)
OPENAI_API_KEY=                # GPT-4o-mini clip scoring
HUGGINGFACE_TOKEN=             # pyannote diarization
WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda           # cuda | cpu (mock uses cpu/no-op)

# ── Storage (Cloudflare R2 / S3 API) ──────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=focaldive-clips
R2_ENDPOINT=

# ── Queue / DB (API + worker) ─────────────────────────────────
DATABASE_URL=postgresql://focaldive:focaldive@localhost:5432/focaldive
REDIS_URL=redis://localhost:6379

# ── Auth (Clerk) ──────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ── Payments (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ── App ───────────────────────────────────────────────────────
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
