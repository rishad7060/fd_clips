# ============================================================
# FocalDive Clips - Docker environment template
# ============================================================
# Copy to .env.docker and fill in real values, then:
#   docker compose --env-file .env.docker up --build -d
# .env.docker is gitignored - never commit real secrets.
# ============================================================

# ── Public URLs (how the browser reaches the API) ──
# For local Docker keep these as localhost. In production set them to your
# real domains (e.g. https://api.focaldive.com / https://app.focaldive.com).
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PUBLIC_URL=http://localhost:4000
BILLING_SUCCESS_URL=http://localhost:3000/billing?ok=1
BILLING_CANCEL_URL=http://localhost:3000/billing?canceled=1

# ── Postgres ──
POSTGRES_USER=focaldive
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=focaldive

# ── Mock toggles ──
# auto = real where keys exist. Keep MOCK_AUTH=true until account creation
# (Clerk) is wired; the API then injects a fake org so everything else works.
MOCK_MODE=auto
MOCK_AUTH=true

# ── Pipeline AI keys (free CPU path) ──
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
SCORING_PROVIDER=gemini
TRANSCRIBE_BACKEND=groq
OPENAI_API_KEY=

# ── Billing (Polar.sh) ──
# Sandbox by default. LIVE: POLAR_BASE_URL=https://api.polar.sh, POLAR_MODE=production,
# and use a PRODUCTION access token + product ids.
POLAR_ACCESS_TOKEN=
POLAR_BASE_URL=https://sandbox-api.polar.sh
POLAR_MODE=sandbox
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_PRO=
# Standard Webhooks secret (Polar Dashboard → Settings → Webhooks). Required so
# credits only grant on genuine Polar events.
POLAR_WEBHOOK_SECRET=

# ── Email (optional) ──
RESEND_API_KEY=
EMAIL_FROM=FocalDive Clips <clips@focaldive.com>

# ── Auth (Clerk) - leave blank while account creation is disabled ──
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
